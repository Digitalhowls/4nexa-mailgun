# services/node-agent/Dockerfile.dev
# Imagen de desarrollo para node-agent (usada por mail-node/docker-compose.yml)
# Usa hot-reload con nest start --watch

FROM node:18-alpine

RUN apk add --no-cache docker-cli

WORKDIR /app

# Copiar manifiestos de dependencias
COPY package.json ./
COPY tsconfig.json ./

# Instalar dependencias (sin monorepo: las workspace:* se resuelven en build)
RUN npm install --legacy-peer-deps 2>/dev/null || true

# Copiar código fuente
COPY src/ ./src/

# Variables de entorno por defecto (sobreescritas por docker-compose)
ENV NODE_ENV=development
ENV AGENT_PORT=3099
ENV AGENT_HOST=0.0.0.0

EXPOSE 3099

CMD ["npx", "ts-node", "-r", "tsconfig-paths/register", "src/main.ts"]
