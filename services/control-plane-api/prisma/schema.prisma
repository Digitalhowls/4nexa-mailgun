// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm, vector]
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
  PENDING_DNS
  PENDING_PAYMENT
}

enum BillingStatus {
  ACTIVE
  GRACE
  RESTRICTED
  SUSPENDED
}

enum DomainStatus {
  PENDING_DNS
  ACTIVE
  SUSPENDED
  DELETED
}

enum DnsRecordStatus {
  UNCHECKED
  VALID
  INVALID
  MISSING
}

enum MailboxStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum NodeStatus {
  ACTIVE
  MAINTENANCE
  DRAINING
  QUARANTINED
  OFFLINE
}

enum BackupType {
  FULL_NODE
  CONFIGURATION
  DATABASE
  MAILBOXES
  TENANT
  DOMAIN
  MAILBOX
}

enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  VERIFIED
}

enum WarmupStatus {
  COLD
  WARMING
  WARM
}

enum AbuseType {
  MASS_SENDING
  COMPROMISED_CREDENTIALS
  EXCESSIVE_BOUNCES
  OUTBOUND_SPAM
  FAILED_AUTH
  SUSPICIOUS_CONNECTION
  QUOTA_ABUSE
}

enum AbuseSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UserRole {
  SUPER_ADMIN
  PLATFORM_ADMIN
  SUPPORT_AGENT
  BILLING_AGENT
  ABUSE_ANALYST
  READ_ONLY_AUDITOR
  TENANT_OWNER
  TENANT_ADMIN
  TENANT_BILLING
  TENANT_MAIL_MANAGER
  TENANT_MAILBOX_USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum MailEventType {
  SENT
  RECEIVED
  DEFERRED
  BOUNCED
  REJECTED
  SPAM_DETECTED
  VIRUS_DETECTED
  AUTH_FAILED
  QUARANTINED
}

// ─────────────────────────────────────────────────────────────────────────────
// Plan — planes de suscripción (§12.5)
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String   @unique @db.VarChar(100)
  maxDomains             Int
  maxMailboxes           Int
  storageTotalBytes      BigInt
  storagePerMailboxBytes BigInt
  outboundDailyLimit     Int
  antivirusEnabled       Boolean  @default(false)
  backupRetentionDays    Int      @default(7)
  priceMonthly           Decimal  @db.Decimal(10, 2)
  priceYearly            Decimal  @db.Decimal(10, 2)
  active                 Boolean  @default(true)
  createdAt              DateTime @default(now()) @db.Timestamptz
  updatedAt              DateTime @updatedAt @db.Timestamptz

  tenants Tenant[]

  @@map("plans")
}

// ─────────────────────────────────────────────────────────────────────────────
// Node — servidores de correo gestionados (§12.6)
// ─────────────────────────────────────────────────────────────────────────────

model Node {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hostname        String        @unique @db.VarChar(253)
  ipV4            String        @db.VarChar(15)
  ipV6            String?       @db.VarChar(45)
  provider        String        @db.VarChar(100)
  region          String        @db.VarChar(100)
  status          NodeStatus    @default(ACTIVE)
  maxTenants      Int           @default(50)
  currentTenants  Int           @default(0)
  reputationScore Int           @default(100)
  capacityScore   Int           @default(100)
  warmupStatus    WarmupStatus  @default(COLD)
  warmupEndsAt    DateTime?     @db.Timestamptz
  lastHealthAt    DateTime?     @db.Timestamptz
  lastAgentAt     DateTime?     @db.Timestamptz
  createdAt       DateTime      @default(now()) @db.Timestamptz
  updatedAt       DateTime      @updatedAt @db.Timestamptz

  tenants      Tenant[]
  domains      Domain[]
  backupJobs   BackupJob[]
  certificates NodeCertificate[]

  @@map("nodes")
}

// ─────────────────────────────────────────────────────────────────────────────
// NodeCertificate — certificados mTLS emitidos por el Control Plane (§17.3)
// ─────────────────────────────────────────────────────────────────────────────

model NodeCertificate {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId       String    @db.Uuid
  node         Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  certPem      String    // X.509 PEM del certificado de servidor del agente
  serialNumber String    @db.VarChar(40)
  fingerprint  String    @db.VarChar(64)    // SHA-256 hex del cert
  issuedAt     DateTime  @default(now()) @db.Timestamptz
  expiresAt    DateTime  @db.Timestamptz
  revokedAt    DateTime? @db.Timestamptz

  @@map("node_certificates")
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenant — organizaciones cliente (§12.1)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String        @db.VarChar(100)
  slug          String        @unique @db.VarChar(63)
  legalName     String?       @db.VarChar(200)
  billingEmail  String        @db.VarChar(254)
  status        TenantStatus  @default(TRIAL)
  billingStatus BillingStatus @default(ACTIVE)
  suspendedAt   DateTime?     @db.Timestamptz
  suspendReason String?       @db.VarChar(500)
  notes         String?       @db.Text
  trustScore    Int           @default(100)
  planId        String?       @db.Uuid
  nodeId        String?       @db.Uuid
  // v3
  origoCustomerId String?     @db.VarChar(100)
  createdAt     DateTime      @default(now()) @db.Timestamptz
  updatedAt     DateTime      @updatedAt @db.Timestamptz

  plan      Plan?     @relation(fields: [planId], references: [id])
  node      Node?     @relation(fields: [nodeId], references: [id])
  domains   Domain[]
  mailboxes Mailbox[]
  aliases   Alias[]
  users     User[]
  migrationJobs        MigrationJob[]
  // v3 relations
  apiKeys              ApiKey[]
  dnsProviders         DnsProvider[]
  whitelabelConfig     WhitelabelConfig?
  archivalPolicy       ArchivalPolicy?
  notificationChannels NotificationChannel[]
  extractedInvoices    ExtractedInvoice[]

  @@index([slug])
  @@index([status])
  @@index([nodeId])
  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// Domain — dominios de correo (§12.2)
// ─────────────────────────────────────────────────────────────────────────────

model Domain {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String          @db.Uuid
  domain                String          @db.VarChar(253)
  status                DomainStatus    @default(PENDING_DNS)
  nodeId                String?         @db.Uuid
  mxStatus              DnsRecordStatus @default(UNCHECKED)
  spfStatus             DnsRecordStatus @default(UNCHECKED)
  dkimStatus            DnsRecordStatus @default(UNCHECKED)
  dmarcStatus           DnsRecordStatus @default(UNCHECKED)
  dkimSelector          String          @default("4nexa") @db.VarChar(63)
  dkimPublicKey         String?         @db.Text
  dkimPrivateKeyEncrypted String?       @db.Text
  healthScore           Int             @default(100)
  lastDnsCheckAt        DateTime?       @db.Timestamptz
  verifiedAt            DateTime?       @db.Timestamptz
  suspendedAt           DateTime?       @db.Timestamptz
  deletedAt             DateTime?       @db.Timestamptz
  createdAt             DateTime        @default(now()) @db.Timestamptz
  updatedAt             DateTime        @updatedAt @db.Timestamptz

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  node      Node?     @relation(fields: [nodeId], references: [id])
  mailboxes      Mailbox[]
  aliases        Alias[]
  antispamPolicy AntispamPolicy?
  // v3 relations
  dnsProvider    DnsProvider?     @relation(fields: [dnsProviderId], references: [id])
  dnsProviderId  String?          @db.Uuid
  bimiConfig     BimiConfig?

  @@unique([tenantId, domain])
  @@index([domain])
  @@index([status])
  @@map("domains")
}

// ─────────────────────────────────────────────────────────────────────────────
// AntispamPolicy — política antispam por dominio (§27)
// ─────────────────────────────────────────────────────────────────────────────

model AntispamPolicy {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domainId        String   @unique @db.Uuid
  enabled         Boolean  @default(true)
  // 0.0–1.0: puntuación ≥ spamThreshold → FLAG (no rechazar, sólo etiquetar)
  spamThreshold   Float    @default(0.80)
  // 0.0–1.0: puntuación ≥ rejectAbove → REJECT
  rejectAbove     Float    @default(0.95)
  greylistEnabled Boolean  @default(false)
  whitelist       String[] @default([])
  blacklist       String[] @default([])
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  domain Domain @relation(fields: [domainId], references: [id])

  @@map("antispam_policies")
}

// ─────────────────────────────────────────────────────────────────────────────
// Mailbox — buzones de correo (§12.3)
// ─────────────────────────────────────────────────────────────────────────────

model Mailbox {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String        @db.Uuid
  domainId           String        @db.Uuid
  localPart          String        @db.VarChar(64)
  passwordHash       String        @db.VarChar(256)
  status             MailboxStatus @default(ACTIVE)
  quotaBytes         BigInt
  usedBytes          BigInt        @default(0)
  forcePasswordReset Boolean       @default(false)
  lastLoginAt        DateTime?     @db.Timestamptz
  suspendedAt        DateTime?     @db.Timestamptz
  deletedAt          DateTime?     @db.Timestamptz
  createdAt          DateTime      @default(now()) @db.Timestamptz
  updatedAt          DateTime      @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  domain Domain @relation(fields: [domainId], references: [id])
  // v3 relations
  calendarConfig    CalendarConfig?
  extractedInvoices ExtractedInvoice[]

  @@unique([domainId, localPart])
  @@index([tenantId])
  @@index([status])
  @@map("mailboxes")
}

// ─────────────────────────────────────────────────────────────────────────────
// Alias — alias de correo (§12.4)
// ─────────────────────────────────────────────────────────────────────────────

model Alias {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  domainId    String   @db.Uuid
  source      String   @db.VarChar(254)
  destination String   @db.VarChar(254)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  domain Domain @relation(fields: [domainId], references: [id])

  @@unique([domainId, source])
  @@index([tenantId])
  @@map("aliases")
}

// ─────────────────────────────────────────────────────────────────────────────
// User — usuarios del panel (§12.9)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String     @unique @db.VarChar(254)
  passwordHash        String     @db.VarChar(256)
  role                UserRole
  status              UserStatus @default(PENDING_VERIFICATION)
  tenantId            String?    @db.Uuid
  totpSecret          String?    @db.VarChar(128)
  totpEnabled         Boolean    @default(false)
  emailVerifiedAt     DateTime?  @db.Timestamptz
  lastLoginAt         DateTime?  @db.Timestamptz
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?  @db.Timestamptz
  createdAt           DateTime   @default(now()) @db.Timestamptz
  updatedAt           DateTime   @updatedAt @db.Timestamptz

  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// RefreshToken — tokens de refresco JWT (§17)
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  jti       String    @unique @db.VarChar(128)
  expiresAt DateTime  @db.Timestamptz
  revokedAt DateTime? @db.Timestamptz
  ipAddress String?   @db.VarChar(45)
  userAgent String?   @db.VarChar(512)
  createdAt DateTime  @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([jti])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// AuditLog — registro inmutable de acciones críticas (§17)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @db.Uuid
  tenantId   String?  @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @db.VarChar(50)
  entityId   String?  @db.Uuid
  metadata   Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(512)
  // HMAC-SHA256 hex para tamper detection (§29.3). Vacío en registros legacy.
  hmac       String   @default("") @db.VarChar(64)
  createdAt  DateTime @default(now()) @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// BackupJob — trabajos de backup (§12.7)
// ─────────────────────────────────────────────────────────────────────────────

model BackupJob {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId       String?      @db.Uuid
  type         BackupType
  status       BackupStatus @default(PENDING)
  snapshotId   String?      @db.VarChar(128)
  sizeBytes    BigInt?
  durationMs   Int?
  errorMessage String?      @db.Text
  startedAt    DateTime?    @db.Timestamptz
  completedAt  DateTime?    @db.Timestamptz
  verifiedAt   DateTime?    @db.Timestamptz
  createdAt    DateTime     @default(now()) @db.Timestamptz

  node Node? @relation(fields: [nodeId], references: [id])

  @@index([nodeId])
  @@index([status])
  @@index([createdAt])
  @@map("backup_jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// AbuseEvent — eventos de abuso detectados (§12.8)
// ─────────────────────────────────────────────────────────────────────────────

model AbuseEvent {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String?       @db.Uuid
  domainId      String?       @db.Uuid
  mailboxId     String?       @db.Uuid
  nodeId        String?       @db.Uuid
  type          AbuseType
  severity      AbuseSeverity
  description   String        @db.Text
  sourceIp      String?       @db.VarChar(45)
  metadata      Json?
  resolvedAt    DateTime?     @db.Timestamptz
  resolvedBy    String?       @db.Uuid
  autoMitigated Boolean       @default(false)
  createdAt     DateTime      @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([type])
  @@index([severity])
  @@index([createdAt])
  @@map("abuse_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// MailEvent — eventos de tráfico de correo (§12)
// ─────────────────────────────────────────────────────────────────────────────

model MailEvent {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String        @db.Uuid
  domainId   String        @db.Uuid
  mailboxId  String?       @db.Uuid
  nodeId     String?       @db.Uuid
  type       MailEventType
  messageId  String?       @db.VarChar(512)
  fromEmail  String?       @db.VarChar(254)
  toEmail    String?       @db.VarChar(254)
  subject    String?       @db.VarChar(998)
  sizeBytes  Int?
  spamScore  Decimal?      @db.Decimal(5, 2)
  errorCode  String?       @db.VarChar(10)
  errorMsg   String?       @db.VarChar(512)
  metadata   Json?
  occurredAt DateTime      @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([domainId])
  @@index([mailboxId])
  @@index([type])
  @@index([occurredAt])
  @@map("mail_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// MemoryCell — memoria operacional del Brain (§14)
// Almacena conocimiento estructurado por scope y clave.
// NUNCA almacena emails completos ni datos PII directos.
// ─────────────────────────────────────────────────────────────────────────────

enum MemoryCellScope {
  REPUTATION
  DELIVERABILITY
  SUPPORT
  ABUSE
  RECOVERY
  MIGRATION
  OPERATIONAL
}

model MemoryCell {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// null = celda global del sistema (sin tenant)
  tenantId   String?         @db.Uuid
  scope      MemoryCellScope
  /// Clave compuesta: ej. "node:{nodeId}:bounce_rate" o "tenant:{id}:risk"
  key        String          @db.VarChar(200)
  /// Payload JSONB — estructura libre, sin PII directa
  payload    Json
  expiresAt  DateTime?       @db.Timestamptz
  createdAt  DateTime        @default(now()) @db.Timestamptz
  updatedAt  DateTime        @updatedAt @db.Timestamptz
  /// userId o "system" — trazabilidad de escritura
  createdBy  String          @default("system") @db.VarChar(100)
  version    Int             @default(1)
  /// v3: embedding pgvector (1536 dims — compatible OpenAI ada-002 / nomic-embed)
  embedding  Unsupported("vector(1536)")?

  @@unique([tenantId, scope, key])
  @@index([tenantId])
  @@index([scope])
  @@index([expiresAt])
  @@map("memory_cells")
}

// ─────────────────────────────────────────────────────────────────────────────
// MigrationJob — trabajos de migración IMAP desde orígenes externos (§15)
// ─────────────────────────────────────────────────────────────────────────────

enum MigrationProvider {
  GOOGLE_WORKSPACE
  MICROSOFT_365
  CPANEL
  PLESK
  ZIMBRA
  GENERIC_IMAP
}

enum MigrationStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────────
// v3 Enums
// ─────────────────────────────────────────────────────────────────────────────

enum DnsProviderType {
  CLOUDFLARE
  HETZNER
  OVH
  ROUTE53
  POWERDNS
  MANUAL
}

enum ApiKeyScope {
  READ_TENANTS
  WRITE_TENANTS
  READ_DOMAINS
  WRITE_DOMAINS
  READ_MAILBOXES
  WRITE_MAILBOXES
  READ_ALIASES
  WRITE_ALIASES
  READ_BILLING
  WRITE_BILLING
  READ_BACKUPS
  EXEC_BACKUPS
  READ_AUDIT
  READ_METRICS
  EXEC_MIGRATIONS
  EXEC_DNS
  ADMIN_ALL
}

enum CalendarShareType {
  PRIVATE
  TENANT_READ
  TENANT_WRITE
  PUBLIC_READ
}

enum ArchivalStorageType {
  LOCAL_S3
  EXTERNAL_S3
  GLACIER
  AZURE_BLOB
}

enum InvoiceExtractionStatus {
  PENDING
  EXTRACTED
  FAILED
  REVIEWED
  EXPORTED
}

enum NotificationType {
  EMAIL
  WEBHOOK
  SLACK
  TEAMS
  SMS
}

model MigrationJob {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String            @db.Uuid
  /// Buzón destino — null = migración a nivel de dominio (todos los buzones del tenant)
  mailboxId             String?           @db.Uuid
  provider              MigrationProvider
  status                MigrationStatus   @default(PENDING)

  /// Servidor IMAP origen
  sourceHost            String            @db.VarChar(255)
  sourcePort            Int               @default(993)
  sourceUsername        String            @db.VarChar(255)
  /// Contraseña cifrada AES-256-GCM — NUNCA en texto plano
  sourceEncryptedPassword String          @db.Text
  sourceTls             Boolean           @default(true)

  /// Progreso incremental
  foldersTotal          Int               @default(0)
  foldersImported       Int               @default(0)
  messagesTotal         Int               @default(0)
  messagesImported      Int               @default(0)
  bytesTotal            BigInt            @default(0)
  bytesImported         BigInt            @default(0)

  errorMessage          String?           @db.Text
  startedAt             DateTime?         @db.Timestamptz
  completedAt           DateTime?         @db.Timestamptz
  createdAt             DateTime          @default(now()) @db.Timestamptz
  updatedAt             DateTime          @updatedAt @db.Timestamptz
  createdBy             String            @db.VarChar(100)

  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([provider])
  @@map("migration_jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// v3 Models
// ─────────────────────────────────────────────────────────────────────────────

// ApiKey — autenticación para API pública (§12)
model ApiKey {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String       @db.Uuid
  name        String       @db.VarChar(100)
  keyHash     String       @unique @db.VarChar(256)
  keyPrefix   String       @db.VarChar(8)
  scopes      ApiKeyScope[]
  rateLimit   Int          @default(1000)
  lastUsedAt  DateTime?    @db.Timestamptz
  expiresAt   DateTime?    @db.Timestamptz
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now()) @db.Timestamptz
  createdBy   String       @db.VarChar(100)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([keyPrefix])
  @@map("api_keys")
}

// DnsProvider — proveedor DNS conectado (§11)
model DnsProvider {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String          @db.Uuid
  provider     DnsProviderType
  encApiKey    String          @db.Text
  encApiSecret String?         @db.Text
  zoneId       String?         @db.VarChar(100)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now()) @db.Timestamptz
  updatedAt    DateTime        @updatedAt @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  domains Domain[]

  @@index([tenantId])
  @@map("dns_providers")
}

// WhitelabelConfig — configuración white-label por tenant (§13)
model WhitelabelConfig {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @unique @db.Uuid
  brandName     String   @db.VarChar(100)
  brandDomain   String   @unique @db.VarChar(253)
  logoUrl       String?  @db.VarChar(512)
  primaryColor  String   @default("#3B82F6") @db.VarChar(7)
  accentColor   String   @default("#10B981") @db.VarChar(7)
  supportEmail  String?  @db.VarChar(254)
  customCss     String?  @db.Text
  smtpFromName  String?  @db.VarChar(100)
  smtpFromEmail String?  @db.VarChar(254)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("whitelabel_configs")
}

// CalendarConfig — configuración SOGo/CalDAV por buzón (§10)
model CalendarConfig {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mailboxId  String            @unique @db.Uuid
  enabled    Boolean           @default(true)
  easEnabled Boolean           @default(false)
  shareType  CalendarShareType @default(PRIVATE)
  createdAt  DateTime          @default(now()) @db.Timestamptz
  updatedAt  DateTime          @updatedAt @db.Timestamptz

  mailbox Mailbox @relation(fields: [mailboxId], references: [id])

  @@map("calendar_configs")
}

// ArchivalPolicy — política de retención y archivado legal (§15)
model ArchivalPolicy {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String              @unique @db.Uuid
  retentionYears  Int                 @default(3)
  autoDeleteAfter Boolean             @default(false)
  encryptArchive  Boolean             @default(true)
  storageBackend  ArchivalStorageType @default(LOCAL_S3)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now()) @db.Timestamptz
  updatedAt       DateTime            @updatedAt @db.Timestamptz

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  legalHolds LegalHold[]

  @@map("archival_policies")
}

// LegalHold — congelación de buzones durante investigación (§15)
model LegalHold {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  archivalPolicyId String    @db.Uuid
  mailboxIds       String[]
  reason           String    @db.Text
  requestedBy      String    @db.VarChar(100)
  startDate        DateTime  @default(now()) @db.Timestamptz
  endDate          DateTime? @db.Timestamptz
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now()) @db.Timestamptz

  archivalPolicy ArchivalPolicy @relation(fields: [archivalPolicyId], references: [id])

  @@index([tenantId])
  @@index([isActive])
  @@map("legal_holds")
}

// BimiConfig — configuración BIMI por dominio (§16)
model BimiConfig {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domainId   String    @unique @db.Uuid
  svgUrl     String    @db.VarChar(512)
  vmcUrl     String?   @db.VarChar(512)
  isActive   Boolean   @default(false)
  verified   Boolean   @default(false)
  verifiedAt DateTime? @db.Timestamptz
  createdAt  DateTime  @default(now()) @db.Timestamptz
  updatedAt  DateTime  @updatedAt @db.Timestamptz

  domain Domain @relation(fields: [domainId], references: [id])

  @@map("bimi_configs")
}

// NotificationChannel — canales de notificación por tenant (§18)
model NotificationChannel {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String           @db.Uuid
  name      String           @db.VarChar(100)
  type      NotificationType
  config    Json
  events    String[]
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now()) @db.Timestamptz
  updatedAt DateTime         @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@map("notification_channels")
}

// ExtractedInvoice — facturas extraídas por IA de correos (§7)
model ExtractedInvoice {
  id            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String                  @db.Uuid
  mailboxId     String                  @db.Uuid
  messageId     String                  @db.VarChar(512)
  invoiceNumber String?                 @db.VarChar(100)
  issuerName    String?                 @db.VarChar(200)
  issuerTaxId   String?                 @db.VarChar(50)
  totalAmount   Decimal?                @db.Decimal(12, 2)
  vatAmount     Decimal?                @db.Decimal(12, 2)
  currency      String                  @default("EUR") @db.VarChar(3)
  invoiceDate   DateTime?               @db.Timestamptz
  confidence    Float                   @default(0)
  status        InvoiceExtractionStatus @default(PENDING)
  createdAt     DateTime                @default(now()) @db.Timestamptz
  updatedAt     DateTime                @updatedAt @db.Timestamptz

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  mailbox Mailbox @relation(fields: [mailboxId], references: [id])

  @@index([tenantId])
  @@index([mailboxId])
  @@index([status])
  @@map("extracted_invoices")
}
