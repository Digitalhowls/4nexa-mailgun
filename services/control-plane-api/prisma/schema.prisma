// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm]
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
  PENDING_DNS
  PENDING_PAYMENT
}

enum BillingStatus {
  ACTIVE
  GRACE
  RESTRICTED
  SUSPENDED
}

enum DomainStatus {
  PENDING_DNS
  ACTIVE
  SUSPENDED
  DELETED
}

enum DnsRecordStatus {
  UNCHECKED
  VALID
  INVALID
  MISSING
}

enum MailboxStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum NodeStatus {
  ACTIVE
  MAINTENANCE
  DRAINING
  QUARANTINED
  OFFLINE
}

enum BackupType {
  FULL_NODE
  CONFIGURATION
  DATABASE
  MAILBOXES
  TENANT
  DOMAIN
  MAILBOX
}

enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  VERIFIED
}

enum AbuseType {
  MASS_SENDING
  COMPROMISED_CREDENTIALS
  EXCESSIVE_BOUNCES
  OUTBOUND_SPAM
  FAILED_AUTH
  SUSPICIOUS_CONNECTION
  QUOTA_ABUSE
}

enum AbuseSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UserRole {
  SUPER_ADMIN
  PLATFORM_ADMIN
  SUPPORT_AGENT
  BILLING_AGENT
  ABUSE_ANALYST
  READ_ONLY_AUDITOR
  TENANT_OWNER
  TENANT_ADMIN
  TENANT_BILLING
  TENANT_MAIL_MANAGER
  TENANT_MAILBOX_USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum MailEventType {
  SENT
  RECEIVED
  DEFERRED
  BOUNCED
  REJECTED
  SPAM_DETECTED
  VIRUS_DETECTED
  AUTH_FAILED
  QUARANTINED
}

// ─────────────────────────────────────────────────────────────────────────────
// Plan — planes de suscripción (§12.5)
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String   @unique @db.VarChar(100)
  maxDomains             Int
  maxMailboxes           Int
  storageTotalBytes      BigInt
  storagePerMailboxBytes BigInt
  outboundDailyLimit     Int
  antivirusEnabled       Boolean  @default(false)
  backupRetentionDays    Int      @default(7)
  priceMonthly           Decimal  @db.Decimal(10, 2)
  priceYearly            Decimal  @db.Decimal(10, 2)
  active                 Boolean  @default(true)
  createdAt              DateTime @default(now()) @db.Timestamptz
  updatedAt              DateTime @updatedAt @db.Timestamptz

  tenants Tenant[]

  @@map("plans")
}

// ─────────────────────────────────────────────────────────────────────────────
// Node — servidores de correo gestionados (§12.6)
// ─────────────────────────────────────────────────────────────────────────────

model Node {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hostname        String     @unique @db.VarChar(253)
  ipV4            String     @db.VarChar(15)
  ipV6            String?    @db.VarChar(45)
  provider        String     @db.VarChar(100)
  region          String     @db.VarChar(100)
  status          NodeStatus @default(ACTIVE)
  maxTenants      Int        @default(50)
  currentTenants  Int        @default(0)
  reputationScore Int        @default(100)
  capacityScore   Int        @default(100)
  lastHealthAt    DateTime?  @db.Timestamptz
  lastAgentAt     DateTime?  @db.Timestamptz
  createdAt       DateTime   @default(now()) @db.Timestamptz
  updatedAt       DateTime   @updatedAt @db.Timestamptz

  tenants    Tenant[]
  domains    Domain[]
  backupJobs BackupJob[]

  @@map("nodes")
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenant — organizaciones cliente (§12.1)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String        @db.VarChar(100)
  slug          String        @unique @db.VarChar(63)
  legalName     String?       @db.VarChar(200)
  billingEmail  String        @db.VarChar(254)
  status        TenantStatus  @default(TRIAL)
  billingStatus BillingStatus @default(ACTIVE)
  suspendedAt   DateTime?     @db.Timestamptz
  suspendReason String?       @db.VarChar(500)
  notes         String?       @db.Text
  planId        String?       @db.Uuid
  nodeId        String?       @db.Uuid
  createdAt     DateTime      @default(now()) @db.Timestamptz
  updatedAt     DateTime      @updatedAt @db.Timestamptz

  plan      Plan?     @relation(fields: [planId], references: [id])
  node      Node?     @relation(fields: [nodeId], references: [id])
  domains   Domain[]
  mailboxes Mailbox[]
  aliases   Alias[]
  users     User[]

  @@index([slug])
  @@index([status])
  @@index([nodeId])
  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// Domain — dominios de correo (§12.2)
// ─────────────────────────────────────────────────────────────────────────────

model Domain {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String          @db.Uuid
  domain                String          @db.VarChar(253)
  status                DomainStatus    @default(PENDING_DNS)
  nodeId                String?         @db.Uuid
  mxStatus              DnsRecordStatus @default(UNCHECKED)
  spfStatus             DnsRecordStatus @default(UNCHECKED)
  dkimStatus            DnsRecordStatus @default(UNCHECKED)
  dmarcStatus           DnsRecordStatus @default(UNCHECKED)
  dkimSelector          String          @default("4nexa") @db.VarChar(63)
  dkimPublicKey         String?         @db.Text
  dkimPrivateKeyEncrypted String?       @db.Text
  lastDnsCheckAt        DateTime?       @db.Timestamptz
  verifiedAt            DateTime?       @db.Timestamptz
  suspendedAt           DateTime?       @db.Timestamptz
  deletedAt             DateTime?       @db.Timestamptz
  createdAt             DateTime        @default(now()) @db.Timestamptz
  updatedAt             DateTime        @updatedAt @db.Timestamptz

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  node      Node?     @relation(fields: [nodeId], references: [id])
  mailboxes Mailbox[]
  aliases   Alias[]

  @@unique([tenantId, domain])
  @@index([domain])
  @@index([status])
  @@map("domains")
}

// ─────────────────────────────────────────────────────────────────────────────
// Mailbox — buzones de correo (§12.3)
// ─────────────────────────────────────────────────────────────────────────────

model Mailbox {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String        @db.Uuid
  domainId           String        @db.Uuid
  localPart          String        @db.VarChar(64)
  passwordHash       String        @db.VarChar(256)
  status             MailboxStatus @default(ACTIVE)
  quotaBytes         BigInt
  usedBytes          BigInt        @default(0)
  forcePasswordReset Boolean       @default(false)
  lastLoginAt        DateTime?     @db.Timestamptz
  suspendedAt        DateTime?     @db.Timestamptz
  deletedAt          DateTime?     @db.Timestamptz
  createdAt          DateTime      @default(now()) @db.Timestamptz
  updatedAt          DateTime      @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  domain Domain @relation(fields: [domainId], references: [id])

  @@unique([domainId, localPart])
  @@index([tenantId])
  @@index([status])
  @@map("mailboxes")
}

// ─────────────────────────────────────────────────────────────────────────────
// Alias — alias de correo (§12.4)
// ─────────────────────────────────────────────────────────────────────────────

model Alias {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  domainId    String   @db.Uuid
  source      String   @db.VarChar(254)
  destination String   @db.VarChar(254)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  domain Domain @relation(fields: [domainId], references: [id])

  @@unique([domainId, source])
  @@index([tenantId])
  @@map("aliases")
}

// ─────────────────────────────────────────────────────────────────────────────
// User — usuarios del panel (§12.9)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String     @unique @db.VarChar(254)
  passwordHash        String     @db.VarChar(256)
  role                UserRole
  status              UserStatus @default(PENDING_VERIFICATION)
  tenantId            String?    @db.Uuid
  totpSecret          String?    @db.VarChar(128)
  totpEnabled         Boolean    @default(false)
  emailVerifiedAt     DateTime?  @db.Timestamptz
  lastLoginAt         DateTime?  @db.Timestamptz
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?  @db.Timestamptz
  createdAt           DateTime   @default(now()) @db.Timestamptz
  updatedAt           DateTime   @updatedAt @db.Timestamptz

  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// RefreshToken — tokens de refresco JWT (§17)
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  jti       String    @unique @db.VarChar(128)
  expiresAt DateTime  @db.Timestamptz
  revokedAt DateTime? @db.Timestamptz
  ipAddress String?   @db.VarChar(45)
  userAgent String?   @db.VarChar(512)
  createdAt DateTime  @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([jti])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// AuditLog — registro inmutable de acciones críticas (§17)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @db.Uuid
  tenantId   String?  @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @db.VarChar(50)
  entityId   String?  @db.Uuid
  metadata   Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(512)
  createdAt  DateTime @default(now()) @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// BackupJob — trabajos de backup (§12.7)
// ─────────────────────────────────────────────────────────────────────────────

model BackupJob {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId       String?      @db.Uuid
  type         BackupType
  status       BackupStatus @default(PENDING)
  snapshotId   String?      @db.VarChar(128)
  sizeBytes    BigInt?
  durationMs   Int?
  errorMessage String?      @db.Text
  startedAt    DateTime?    @db.Timestamptz
  completedAt  DateTime?    @db.Timestamptz
  verifiedAt   DateTime?    @db.Timestamptz
  createdAt    DateTime     @default(now()) @db.Timestamptz

  node Node? @relation(fields: [nodeId], references: [id])

  @@index([nodeId])
  @@index([status])
  @@index([createdAt])
  @@map("backup_jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// AbuseEvent — eventos de abuso detectados (§12.8)
// ─────────────────────────────────────────────────────────────────────────────

model AbuseEvent {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String?       @db.Uuid
  domainId      String?       @db.Uuid
  mailboxId     String?       @db.Uuid
  nodeId        String?       @db.Uuid
  type          AbuseType
  severity      AbuseSeverity
  description   String        @db.Text
  sourceIp      String?       @db.VarChar(45)
  metadata      Json?
  resolvedAt    DateTime?     @db.Timestamptz
  resolvedBy    String?       @db.Uuid
  autoMitigated Boolean       @default(false)
  createdAt     DateTime      @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([type])
  @@index([severity])
  @@index([createdAt])
  @@map("abuse_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// MailEvent — eventos de tráfico de correo (§12)
// ─────────────────────────────────────────────────────────────────────────────

model MailEvent {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String        @db.Uuid
  domainId   String        @db.Uuid
  mailboxId  String?       @db.Uuid
  nodeId     String?       @db.Uuid
  type       MailEventType
  messageId  String?       @db.VarChar(512)
  fromEmail  String?       @db.VarChar(254)
  toEmail    String?       @db.VarChar(254)
  subject    String?       @db.VarChar(998)
  sizeBytes  Int?
  spamScore  Decimal?      @db.Decimal(5, 2)
  errorCode  String?       @db.VarChar(10)
  errorMsg   String?       @db.VarChar(512)
  metadata   Json?
  occurredAt DateTime      @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([domainId])
  @@index([mailboxId])
  @@index([type])
  @@index([occurredAt])
  @@map("mail_events")
}
