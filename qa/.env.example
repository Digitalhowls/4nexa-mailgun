# URL base del Control Plane API (sin barra final)
QA_API_URL=http://localhost:3001

# URL del Admin Panel (Next.js)
ADMIN_URL=http://localhost:3000

# URL del Customer Panel (Next.js)
CUSTOMER_URL=http://localhost:3002

# Secret JWT igual al usado en el backend (ver services/control-plane-api/.env)
JWT_ACCESS_SECRET=dev-secret-change-in-production

# Credenciales de un tenant real para tests de tenant
QA_TENANT_ID=tenant-qa-001
QA_TENANT_EMAIL=qa-tenant@4nexa.io

# Nivel de log del agent CLI: silent | normal | verbose
QA_LOG_LEVEL=normal

# Timeout en ms para cada solicitud HTTP
QA_REQUEST_TIMEOUT=10000
