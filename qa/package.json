{
  "name": "@4nexa/qa",
  "version": "0.1.0",
  "private": true,
  "description": "QA Autopilot — Sistema automático de testing, depuración y validación integral",
  "scripts": {
    "scan":     "tsx src/scanner/index.ts",
    "api":      "jest --config jest.api.config.ts --passWithNoTests --forceExit",
    "security": "jest --config jest.security.config.ts --passWithNoTests --forceExit",
    "e2e":      "playwright test",
    "e2e:ui":   "playwright test --ui",
    "perf":     "tsx src/performance/api-load.ts",
    "report":   "tsx src/reporter/index.ts",
    "all":      "tsx src/agent/index.ts",
    "all:ci":   "tsx src/agent/index.ts --ci"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "axios": "^1.7.2",
    "jsonwebtoken": "^9.0.2"
  }
}
