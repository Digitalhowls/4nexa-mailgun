# ============================================================
# 4nexa Mailgun — Variables de entorno
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA cometas .env al repositorio.
# ============================================================

# ── Entorno ──────────────────────────────────────────────────
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL="postgresql://mailgun:changeme@localhost:5432/mailgun_dev?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# ── JWT ──────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_64_CHARS
JWT_REFRESH_EXPIRES_IN=7d

# ── Control Plane API ─────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
API_PREFIX=api/v1
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Cifrado de claves DKIM ────────────────────────────────────
# Generar con: openssl rand -hex 32
DKIM_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX_KEY

# ── Node Agent ────────────────────────────────────────────────
NODE_AGENT_MTLS_CERT_PATH=/etc/mailgun/certs/agent.crt
NODE_AGENT_MTLS_KEY_PATH=/etc/mailgun/certs/agent.key
NODE_AGENT_MTLS_CA_PATH=/etc/mailgun/certs/ca.crt
# Secreto compartido Control Plane ↔ Node Agent (min 32 chars)
# Generar con: openssl rand -base64 48
NODE_AGENT_JWT_SECRET=CHANGE_ME_AGENT_JWT_SECRET_MIN_32_CHARS
NODE_AGENT_JWT_EXPIRES_IN=5m
NODE_AGENT_BASE_URL=http://localhost:3099/agent

# ── Node Agent standalone (solo si arrancas services/node-agent) ─
AGENT_PORT=3099
AGENT_HOST=0.0.0.0
# UUID del nodo que este agente representa (debe coincidir con el ID en la BD)
AGENT_NODE_ID=00000000-0000-0000-0000-000000000001

# ── Backups (Restic + S3) ─────────────────────────────────────
BACKUP_S3_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
BACKUP_S3_BUCKET=mailgun-backups
BACKUP_S3_ACCESS_KEY=CHANGE_ME
BACKUP_S3_SECRET_KEY=CHANGE_ME
BACKUP_RESTIC_PASSWORD=CHANGE_ME_RESTIC_REPO_PASSWORD

# ── DNS Checker ───────────────────────────────────────────────
DNS_RESOLVER_TIMEOUT_MS=5000
DNS_RESOLVER_RETRIES=2

# ── Rate Limiting ─────────────────────────────────────────────
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Docker / Producción (§36) ─────────────────────────────────
# Variables usadas en docker-compose.prod.yml y docker-compose.staging.yml
POSTGRES_DB=4nexa
POSTGRES_USER=4nexa
POSTGRES_PASSWORD=CHANGE_ME_secure_postgres_password
# API_PUBLIC_URL: URL pública que los paneles usan para llamar a la API
API_PUBLIC_URL=https://api.tudominio.com
# CORS_ORIGINS: dominios permitidos (separados por coma, sin espacios)
CORS_ORIGINS=https://erp.tudominio.com,https://mail.tudominio.com
# INTERNAL_API_KEY: clave interna Control Plane ↔ Node Agent extra
# Generar con: openssl rand -hex 32
INTERNAL_API_KEY=CHANGE_ME_internal_api_key_hex32

# ── Observabilidad (§ Monitoring) — docker-compose.monitoring.yml ─────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password
GRAFANA_ROOT_URL=https://metrics.tudominio.com
# SEED opcionales para bootstrap inicial
SEED_ADMIN_EMAIL=admin@tudominio.com
SEED_ADMIN_PASSWORD=CHANGE_ME_first_admin_password
SEED_PLATFORM_ADMIN_EMAIL=ops@tudominio.com
SEED_PLATFORM_ADMIN_PASSWORD=CHANGE_ME_platform_admin_password
SEED_NODE_HOSTNAME=mail1.tudominio.com
SEED_NODE_IP=1.2.3.4
