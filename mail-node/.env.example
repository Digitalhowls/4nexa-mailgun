# ─── mail-node/.env.example ────────────────────────────────────────────────
# Copiar a .env y ajustar antes de ejecutar docker-compose up

# ─── Identificación del nodo ──────────────────────────────────────────────
# UUID del nodo registrado en el Control Plane (tabla Node)
AGENT_NODE_ID=00000000-0000-0000-0000-000000000001

# Hostname FQDN del nodo de correo (debe coincidir con el registro MX del dominio)
MAILNODE_HOSTNAME=mail.example.com

# ─── Node Agent ───────────────────────────────────────────────────────────
# Secreto compartido con el Control Plane para validar JWT (mínimo 32 caracteres)
AGENT_JWT_SECRET=cambia-esto-por-un-secreto-seguro-de-al-menos-32-chars

# Clave AES-256 para descifrar claves privadas DKIM
# Debe ser IDÉNTICA a DKIM_ENCRYPTION_KEY del Control Plane
AGENT_DKIM_ENCRYPTION_KEY=cambia-esto-por-una-clave-de-32-chars!!!

# ─── Puertos expuestos (ajustar si hay conflictos) ────────────────────────
SMTP_PORT=25
SMTPS_PORT=465
SUBMISSION_PORT=587
IMAP_PORT=143
IMAPS_PORT=993
AGENT_PORT=3099
RSPAMD_WEB_PORT=11334
