{
  "uid": "4nexa-overview",
  "title": "4nexa Mailgun — Overview",
  "description": "Dashboard principal de la plataforma 4nexa Mailgun",
  "tags": ["4nexa", "mailgun", "production"],
  "timezone": "Europe/Madrid",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API — Estado",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "up{job=\"control-plane-api\"}",
          "legendFormat": "API"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API — Latencia P50 / P95 / P99",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"control-plane-api\"}[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"control-plane-api\"}[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"control-plane-api\"}[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "API — Requests/s por status",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"control-plane-api\", status=~\"2..\"}[1m])",
          "legendFormat": "2xx"
        },
        {
          "expr": "rate(http_requests_total{job=\"control-plane-api\", status=~\"4..\"}[1m])",
          "legendFormat": "4xx"
        },
        {
          "expr": "rate(http_requests_total{job=\"control-plane-api\", status=~\"5..\"}[1m])",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "RAM usada",
      "gridPos": { "x": 0, "y": 8, "w": 4, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Disco /",
      "gridPos": { "x": 4, "y": 8, "w": 4, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(1 - (node_filesystem_free_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
          "legendFormat": "Disco %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU — carga del sistema",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "CPU % {{ instance }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Redis — comandos/s y latencia",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "Comandos/s"
        },
        {
          "expr": "redis_commands_duration_seconds_total / redis_commands_processed_total",
          "legendFormat": "Latencia media (s)"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "BullMQ — trabajos en cola por estado",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "4nexa_mailgun_queue_jobs_total{queue=\"system-events\",state=\"waiting\"}",
          "legendFormat": "En espera"
        },
        {
          "expr": "4nexa_mailgun_queue_jobs_total{queue=\"system-events\",state=\"active\"}",
          "legendFormat": "Activos"
        },
        {
          "expr": "4nexa_mailgun_queue_jobs_total{queue=\"system-events\",state=\"failed\"}",
          "legendFormat": "Fallidos"
        },
        {
          "expr": "4nexa_mailgun_queue_jobs_total{queue=\"system-events-dlq\",state=\"waiting\"}",
          "legendFormat": "DLQ en espera"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Reputación de nodos",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "4nexa_mailgun_node_reputation_score",
          "legendFormat": "{{ hostname }} ({{ node_id }})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "includeAll": false
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" }
}
